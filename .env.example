# ═══════════ HalaGo CMS — Environment Variables ═══════════
# انسخ هذا الملف إلى .env (محلّي) أو أضف القيم في:
#   Vercel → Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════

# ─── قاعدة بيانات Neon (PostgreSQL serverless) ─────────────
# من لوحة Neon → Connection Details، انسخ الرابطين:
#  • DATABASE_URL = الرابط بوضع "Pooled connection" (يحتوي -pooler)
#  • DIRECT_URL   = الرابط بوضع "Direct connection" (بدون -pooler) — للـ migrations
# لازم يبقى ?sslmode=require في آخر الرابط.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require"

# ─── سرّ توقيع JWT ──────────────────────────────────────────
# توليد سريع (PowerShell):
#   [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(48))
# توليد سريع (bash/openssl):
#   openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# ─── اسم التطبيق (يُعرض على الواجهة) ────────────────────────
NEXT_PUBLIC_APP_NAME="HalaGo CMS"

# ─── Mobile API (/api/v1/*) — تطبيقَا Customer و Driver ────
# سرّ توقيع access/refresh tokens للموبايل (منفصل عن JWT_SECRET للأدمن)
MOBILE_JWT_SECRET="change-me-mobile-access-secret-32-chars-min"
MOBILE_REFRESH_SECRET="change-me-mobile-refresh-secret-32-chars-min"

# مزوّد الـ SMS لإرسال OTP:
#   console  → dev mode: يطبع الرمز ويُرجعه في رد الـ API (devCode)
#   unifonic → الإنتاج: يستخدم UNIFONIC_APP_SID + UNIFONIC_SENDER_ID
MOBILE_SMS_PROVIDER="console"
# UNIFONIC_APP_SID=""
# UNIFONIC_SENDER_ID="HalaGo"

# ─── المهام المجدولة (Vercel Cron) ─────────────────────────
# سرّ يحمي مسارات /api/cron/* — يُرسل في ترويسة Authorization: Bearer <CRON_SECRET>
# (إن تُرك فارغاً تعمل المسارات بدون حماية — للتطوير فقط)
CRON_SECRET="change-me-cron-secret"

# ─── مسافة الطريق الفعلية (بدل الخط الهوائي) ────────────────
# OSRM_URL: خادم توجيه OSRM لحساب مسافة الطريق الحقيقية (مثال: https://router.project-osrm.org)
# إن تُرك فارغاً يُستخدم تقريب = المسافة الهوائية × ROAD_DISTANCE_FACTOR
# OSRM_URL=""
ROAD_DISTANCE_FACTOR="1.3"

# ─── (اختياري) خدمات لاحقة ──────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=""           # تكامل Sentry للأخطاء
# FIREBASE_SERVER_KEY=""              # FCM للإشعارات Push
# FIREBASE_PROJECT_ID=""              # FCM للإشعارات Push
# TWILIO_ACCOUNT_SID=""               # SMS Gateway (بديل)
# TWILIO_AUTH_TOKEN=""

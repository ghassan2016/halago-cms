// HalaGo CMS — Prisma schema
// لتحويلها لـ SQLite: غيّر provider إلى "sqlite" وعدّل DATABASE_URL.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("super_admin")
  avatar    String?
  active    Boolean  @default(true)
  vendorId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor? @relation(fields: [vendorId], references: [id], onDelete: SetNull)
}

model Driver {
  id            Int      @id @default(autoincrement())
  name          String
  email         String?  @unique
  phone         String
  avatar        String?
  status        String   @default("pending")
  available     Boolean  @default(false)
  vehicleType   String   @default("car")
  carMake       String?
  carModel      String?
  plateNumber   String?
  rating        Float    @default(5)
  tier          String   @default("bronze") // bronze | silver | gold | platinum (يُحتسب من التقييم وعدد الرحلات)
  totalTrips    Int      @default(0)
  walletBalance Float    @default(0)
  city          String?
  lat           Float?
  lng           Float?
  banReason     String? // سبب الحظر النهائي إن وُجد
  createdAt     DateTime @default(now())

  trips       Trip[]
  withdrawals WithdrawalRequest[]
  documents   DriverDocument[]
  shifts      DriverShift[]
  inspections VehicleInspection[]
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  email         String?  @unique
  phone         String
  avatar        String?
  active        Boolean  @default(true)
  walletBalance Float    @default(0)
  rating        Float    @default(5)
  totalTrips    Int      @default(0)
  city          String?
  createdAt     DateTime @default(now())

  trips Trip[]
}

model Vendor {
  id         Int      @id @default(autoincrement())
  name       String
  category   String   @default("restaurant")
  logo       String?
  status     String   @default("open")
  commission Float    @default(15)
  rating     Float    @default(5)
  address    String?
  phone      String?
  createdAt  DateTime @default(now())

  products Product[]
  trips    Trip[]
  admins   Admin[]
}

model Product {
  id        Int      @id @default(autoincrement())
  vendorId  Int
  name      String
  price     Float
  image     String?
  category  String?
  available Boolean  @default(true)
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Trip {
  id            Int       @id @default(autoincrement())
  number        String    @unique
  type          String    @default("ride")
  status        String    @default("completed")
  customerId    Int?
  driverId      Int?
  vendorId      Int?
  pickupAddress String?
  pickupLat     Float?
  pickupLng     Float?
  dropAddress   String?
  dropLat       Float?
  dropLng       Float?
  city          String?
  distance      Float     @default(0)
  duration      Int       @default(0)
  fare          Float     @default(0)
  commission    Float     @default(0)
  paymentMethod String    @default("cash")
  paymentStatus String    @default("paid")
  rating        Float?
  scheduledAt   DateTime?
  autoAssignedAt DateTime? // وقت التعيين التلقائي للسائق (للرحلات المجدولة)
  cancelReasonKey String? // مفتاح سبب الإلغاء
  cancelReason    String? // نص سبب الإلغاء
  cancelledBy     String? // customer | driver | admin
  cancelledAt     DateTime?
  cancelAction    String? // accepted | fee_charged | escalated
  createdAt     DateTime  @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  driver   Driver?   @relation(fields: [driverId], references: [id])
  vendor   Vendor?   @relation(fields: [vendorId], references: [id])
  messages TripMessage[]
}

// رسائل الدردشة بين العميل والكابتن لكل رحلة
model TripMessage {
  id         Int       @id @default(autoincrement())
  tripId     Int
  senderType String // customer | driver
  senderId   Int
  text       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  type      String // topup | ride_payment | commission | payout | refund | adjustment | cancellation_fee
  amount    Float // موجب = دائن للمحفظة، سالب = خصم
  actorType String
  actorId   Int?
  actorName String?
  refId     Int?
  note      String? // سبب التعديل اليدوي / التعويض
  createdById   Int?
  createdByName String?
  status    String   @default("success")
  createdAt DateTime @default(now())

  @@index([actorType, actorId])
}

model Promo {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  type        String   @default("percentage")
  value       Float
  maxDiscount Float?
  minOrder    Float    @default(0)
  usageLimit  Int      @default(100)
  usedCount   Int      @default(0)
  service     String   @default("all")
  validFrom   DateTime @default(now())
  validTo     DateTime
  status      String   @default("active")
  createdAt   DateTime @default(now())
}

model WithdrawalRequest {
  id        Int      @id @default(autoincrement())
  driverId  Int
  amount    Float
  method    String   @default("bank")
  status    String   @default("pending")
  note      String?
  createdAt DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Notification {
  id         Int      @id @default(autoincrement())
  title      String
  body       String
  audience   String   @default("all")
  recipients Int      @default(0)
  sentBy     String?
  createdAt  DateTime @default(now())
}

model PricingRule {
  id              Int      @id @default(autoincrement())
  vehicleType     String
  serviceType     String   @default("ride")
  distanceUnit    String   @default("km")
  baseFare        Float    @default(5)
  bookingFee      Float    @default(2)
  perKm           Float    @default(1.5)
  perMinute       Float    @default(0.5)
  waitPerMinute   Float    @default(0.5)
  freeWaitMinutes Int      @default(5)
  minimumFare     Float    @default(10)
  cancellationFee Float    @default(5)
  taxPercent      Float    @default(15)
  currency        String   @default("ر.س")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([vehicleType, serviceType])
}

model VehicleClass {
  id         Int      @id @default(autoincrement())
  key        String   @unique
  name       String
  multiplier Float    @default(1)
  capacity   Int      @default(4)
  active     Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
}

model ExtraFee {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  name      String
  amount    Float
  scope     String   @default("global") // global | zone (الرسم الخاص بمنطقة)
  zoneId    Int? // المنطقة التي يُطبّق فيها الرسم عند scope=zone
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([zoneId])
}

model Zone {
  id              Int      @id @default(autoincrement())
  name            String
  city            String
  centerLat       Float
  centerLng       Float
  radiusKm        Float    @default(10)
  priceMultiplier Float    @default(1)
  currencyCode    String   @default("SAR")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model SurgeRule {
  id         Int      @id @default(autoincrement())
  name       String
  days       String   @default("0,1,2,3,4,5,6")
  startHour  Int      @default(7)
  endHour    Int      @default(9)
  multiplier Float    @default(1.5)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model DriverDocument {
  id         Int       @id @default(autoincrement())
  driverId   Int
  type       String
  fileUrl    String?
  number     String?
  status     String    @default("pending")
  note       String?
  expiryDate DateTime?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, type])
}

model Review {
  id        Int      @id @default(autoincrement())
  tripId    Int?
  tripNo    String?
  fromType  String
  fromId    Int?
  fromName  String?
  toType    String
  toId      Int?
  toName    String?
  stars     Int      @default(5)
  comment   String?
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?
  actorName String?
  actorRole String?
  action    String
  entity    String
  entityId  Int?
  meta      String?
  createdAt DateTime @default(now())
}

model SosAlert {
  id            Int       @id @default(autoincrement())
  reporterType  String
  reporterId    Int?
  reporterName  String?
  reporterPhone String?
  tripId        Int?
  tripNumber    String?
  lat           Float?
  lng           Float?
  city          String?
  reason        String    @default("panic")
  severity      String    @default("high")
  status        String    @default("open")
  note          String?
  resolution    String?
  handlerId     Int?
  handlerName   String?
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SupportTicket {
  id            Int       @id @default(autoincrement())
  number        String    @unique
  subject       String
  body          String
  category      String    @default("general")
  priority      String    @default("normal")
  status        String    @default("open")
  reporterType  String
  reporterId    Int?
  reporterName  String?
  reporterEmail String?
  reporterPhone String?
  tripId        Int?
  tripNumber    String?
  assigneeId    Int?
  assigneeName  String?
  lastReplyBy   String?
  lastReplyAt   DateTime?
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages TicketMessage[]
}

model TicketMessage {
  id         Int      @id @default(autoincrement())
  ticketId   Int
  senderType String
  senderId   Int?
  senderName String?
  body       String
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model FraudFlag {
  id          Int       @id @default(autoincrement())
  subjectType String
  subjectId   Int
  subjectRef  String?
  reason      String
  score       Int       @default(50)
  severity    String    @default("medium")
  status      String    @default("open")
  evidence    String?
  note        String?
  handlerId   Int?
  handlerName String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([subjectType, subjectId])
  @@index([status, severity])
}

model ReferralCode {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  ownerType    String
  ownerId      Int
  ownerName    String?
  usageCount   Int      @default(0)
  rewardPerUse Float    @default(10)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  referrals Referral[]

  @@unique([ownerType, ownerId])
}

model Referral {
  id           Int       @id @default(autoincrement())
  codeId       Int
  code         String
  referrerType String
  referrerId   Int
  referrerName String?
  refereeType  String
  refereeId    Int
  refereeName  String?
  status       String    @default("pending")
  reward       Float     @default(0)
  rewardedAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  refCode ReferralCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
}

model VehicleInspection {
  id           Int       @id @default(autoincrement())
  driverId     Int
  type         String    @default("pre_trip")
  odometerKm   Int?
  items        String?
  photos       String?
  notes        String?
  damageScore  Int       @default(0)
  status       String    @default("submitted")
  reviewerId   Int?
  reviewerName String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, createdAt])
}

model CancellationReason {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  labelAr   String
  labelEn   String
  audience  String   @default("both")
  actionType    String  @default("auto_accept") // auto_accept | require_approval | escalate_support
  refundPercent Float   @default(0) // نسبة الاسترداد للزبون عند هذا السبب (0-100)
  chargeFee     Boolean @default(false) // هل يُطبّق رسم إلغاء
  description   String? // شرح الإجراء المتّبع
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model BlockedEntity {
  id            Int       @id @default(autoincrement())
  kind          String
  value         String
  reason        String?
  blockedById   Int?
  blockedByName String?
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  @@unique([kind, value])
}

model TripBreadcrumb {
  id         Int      @id @default(autoincrement())
  tripId     Int
  sequence   Int
  lat        Float
  lng        Float
  speed      Float    @default(0)
  recordedAt DateTime @default(now())

  @@index([tripId, sequence])
}

model Currency {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  nameAr    String
  symbol    String
  fxRate    Float    @default(1)
  isBase    Boolean  @default(false)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationTemplate {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  name      String
  title     String
  body      String
  audience  String   @default("all")
  variables String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DriverShift {
  id             Int       @id @default(autoincrement())
  driverId       Int
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  durationMin    Int       @default(0)
  totalTrips     Int       @default(0)
  completedTrips Int       @default(0)
  cancelledTrips Int       @default(0)
  totalEarnings  Float     @default(0)
  totalKm        Float     @default(0)
  city           String?
  status         String    @default("active")

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, startedAt])
}

// رمز OTP لتسجيل الدخول في تطبيق الموبايل
model OtpCode {
  id        Int      @id @default(autoincrement())
  sessionId String   @unique
  phone     String
  role      String   @default("customer")
  codeHash  String
  attempts  Int      @default(0)
  consumed  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, createdAt])
}

// جهاز موبايل مسجّل (FCM token) لإرسال الإشعارات
model DeviceToken {
  id         Int      @id @default(autoincrement())
  ownerType  String
  ownerId    Int
  token      String   @unique
  platform   String   @default("android")
  locale     String   @default("ar")
  appVersion String?
  active     Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([ownerType, ownerId])
}

// محاولة شحن محفظة عبر بوّابة دفع (Moyasar)
model PaymentIntent {
  id          Int      @id @default(autoincrement())
  reference   String   @unique // رقم العملية الداخلي HG-PAY-...
  providerId  String? // معرّف Moyasar
  ownerType   String   @default("customer") // customer (لاحقاً driver)
  ownerId     Int
  amount      Float // بالعملة الأساسية (ر.س)
  currency    String   @default("SAR")
  purpose     String   @default("wallet_topup") // wallet_topup | ride_payment
  status      String   @default("pending") // pending | succeeded | failed | cancelled
  provider    String   @default("moyasar") // moyasar | dev
  redirectUrl String? // checkout URL من Moyasar
  meta        String? // JSON تفاصيل
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerType, ownerId])
}

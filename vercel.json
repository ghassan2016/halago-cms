{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/dashboard/route.ts": { "maxDuration": 30 },
    "src/app/api/heatmap/route.ts": { "maxDuration": 30 },
    "src/app/api/earnings/route.ts": { "maxDuration": 30 },
    "src/app/api/reports/route.ts": { "maxDuration": 30 },
    "src/app/api/fraud/scan/route.ts": { "maxDuration": 60 },
    "src/app/api/dispatch/route.ts": { "maxDuration": 15 }
  },
  "crons": []
}
